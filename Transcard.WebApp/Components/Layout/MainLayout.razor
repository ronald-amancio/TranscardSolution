@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="d-flex flex-column min-vh-100">

    <!-- Top Navbar -->
    <header class="navbar navbar-expand-lg navbar-light bg-white shadow-sm px-3">

        <div class="container-fluid">

            <!-- Brand -->
            <a class="navbar-brand d-flex align-items-center fw-bold" href="/">
                <img src="resources/images/transcard-logo.png"
                     alt="Transcard Logo"
                     class="brand-logo me-2" />
                <span class="brand-text">Transcard</span>
            </a>

            <!-- Toggle button for mobile -->
            @* <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button> *@
            @* <button class="navbar-toggler"
                    @onclick="ToggleMenu">
                <span class="navbar-toggler-icon"></span>
            </button> *@

            <!-- Collapsible Content -->
            @* <div class="collapse navbar-collapse justify-content-end"
                 id="navbarContent"> *@
            <div class="@MenuCss">

                <AuthorizeView Context="authState">

                    <Authorized>

                        <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">

                            <span class="text-muted small">
                                Hello,
                                <strong>@authState.User.Identity?.Name</strong>
                            </span>

                            <form method="post" action="/auth/logout">
                                <button type="submit"
                                        class="btn btn-outline-danger btn-sm">
                                    Logout
                                </button>
                            </form>

                        </div>

                    </Authorized>

                </AuthorizeView>

            </div>

        </div>

    </header>

    <!-- Main Content -->
    <main class="flex-fill bg-light py-4">
        <div class="container">
            @Body
        </div>
    </main>

    <!-- Session Warning -->
    @if (_showSessionWarning)
    {
        <div class="modal fade show d-block"
             style="background: rgba(0,0,0,0.5);">

            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title text-warning">
                            Session Expiring
                        </h5>
                    </div>

                    <div class="modal-body">
                        You have been inactive.
                        Your session will expire in 1 minute.
                        Do you want to continue?
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary"
                                @onclick="LogoutNow">
                            No
                        </button>

                        <button class="btn btn-primary"
                                @onclick="ContinueSession">
                            Yes, Continue
                        </button>
                    </div>

                </div>
            </div>
        </div>
    }

    <!-- Footer -->
    <footer class="bg-white border-top text-center py-3 small text-muted">
        © @DateTime.Now.Year Transcard. Internal System.
    </footer>

</div>

<!-- Toast -->
@if (_toastMessage != null)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show align-items-center text-white @( _toastSuccess ? "bg-success" : "bg-danger") border-0">
            <div class="d-flex">
                <div class="toast-body">
                    @_toastMessage
                </div>
            </div>
        </div>
    </div>
}

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>